{
  "name": "coderssecret-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production && node scripts/generate-sitemap.js && node scripts/generate-routes.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "check:vulnerabilities": "npm audit --audit-level=high --omit=dev",
    "check:build": "ng build --configuration production",
    "check:seo": "node scripts/check-seo.js",
    "precommit": "run-s check:vulnerabilities check:build check:seo"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "dependencies": {
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@jsverse/transloco": "^8.3.0",
    "@spartan-ng/brain": "^0.0.1-alpha.660",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@spartan-ng/cli": "^0.0.1-alpha.660",
    "@tailwindcss/postcss": "^4.2.2",
    "jsdom": "^28.0.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
